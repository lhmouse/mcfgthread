[binaries]
c = [ 'C:\Program Files\LLVM\bin\clang', '--target=x86_64-pc-windows-msvc', '-fuse-ld=lld' ]
cpp = [ 'C:\Program Files\LLVM\bin\clang++', '--target=x86_64-pc-windows-msvc', '-fuse-ld=lld' ]
ar = 'C:\Program Files\LLVM\bin\llvm-ar'
objcopy = [ 'C:\Program Files\LLVM\bin\llvm-objcopy', '--target=x86_64-pc-windows-msvc' ]
strip = 'C:\Program Files\LLVM\bin\llvm-strip'
windres = [ 'C:\Program Files\LLVM\bin\llvm-rc', '--target=x86_64-pc-windows-msvc' ]
dlltool = [ 'C:\Program Files\LLVM\bin\llvm-dlltool', '-m', 'i386:x86-64' ]

pkg-config = 'x86_64-pc-windows-msvc-pkg-config'
exe_wrapper = 'wine'

[host_machine]
system = 'windows'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'

[properties]
skip_sanity_check = true
